# ============================================================
# FORGE — Environment Variables Template
# Copy to .env.local and fill in real values
# NEVER commit .env.local to git
# ============================================================

# ── LLM APIs ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
GOOGLE_GENERATIVE_AI_API_KEY=AIza...
PERPLEXITY_API_KEY=pplx-...
OPENAI_API_KEY=sk-...              # embeddings + Whisper only

# ── Platform Auth ─────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Supabase (Platform DB) ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # NEVER expose to client
DATABASE_URL=postgresql://postgres:...@db.xxx.supabase.co:5432/postgres

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_STUDIO_PRICE_ID=price_...   # $99/month
STRIPE_AGENCY_PRICE_ID=price_...   # $299/month

# ── Memory & Vector DBs ───────────────────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_COLLECTIVE=forge-collective-brain
PINECONE_INDEX_CODEBASE=forge-codebase

NEO4J_URI=bolt://localhost:7687    # neo4j://xxx.databases.neo4j.io in prod
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=forge_neo4j_pw

REDIS_URL=redis://localhost:6379   # redis://xxx.upstash.io in prod

MEM0_API_KEY=m0-...

# ── Sandbox Execution ─────────────────────────────────────
E2B_API_KEY=e2b_...

# ── Deployment ────────────────────────────────────────────
VERCEL_TOKEN=...
VERCEL_ORG_ID=team_...
RAILWAY_TOKEN=...
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_ACCOUNT_ID=...

# ── Observability ─────────────────────────────────────────
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=forge-production
SENTRY_DSN=https://...@o123.ingest.sentry.io/456
SENTRY_ORG=forge
SENTRY_PROJECT=forge-python

# ── ML Compute ────────────────────────────────────────────
MODAL_TOKEN_ID=ak-...
MODAL_TOKEN_SECRET=as-...

# ── External Services ─────────────────────────────────────
UPTIME_ROBOT_API_KEY=ur...

# ── Local Dev Overrides ───────────────────────────────────
# Uncomment for local development with docker-compose:
# DATABASE_URL=postgresql://forge:forge_local_pw@localhost:5432/forge_db
# REDIS_URL=redis://localhost:6379
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=forge_neo4j_pw
